#!/usr/bin/env python3

import os
import sys
import time
import subprocess
import yaml
import shutil
import socket
import json
import platform
import requests
from datetime import datetime, timezone

# Paths
ROOT_DIR          = os.path.dirname(os.path.abspath(__file__))
MANIFEST_PATH     = os.path.join(ROOT_DIR, "manifest.yaml")
NGINX_TEMPLATE    = os.path.join(ROOT_DIR, "templates", "nginx.conf.template")
COMPOSE_TEMPLATE  = os.path.join(ROOT_DIR, "templates", "docker-compose.yml.template")
NGINX_OUT         = os.path.join(ROOT_DIR, "nginx.conf")
COMPOSE_OUT       = os.path.join(ROOT_DIR, "docker-compose.yml")


# HELPERS

def log(msg):
    """Print a message with a prefix."""
    print(f"[swiftdeploy] {msg}")


def success(msg):
    print(f"{msg}")


def fail(msg):
    print(f"{msg}")


def run(cmd, capture=False):
    """Run a shell command. Exit on failure."""
    result = subprocess.run(cmd, shell=True, capture_output=capture, text=True)
    if result.returncode != 0:
        if capture:
            print(result.stderr)
        sys.exit(1)
    return result


def load_manifest():
    """Read and parse manifest.yaml. Exit if missing or invalid."""
    if not os.path.exists(MANIFEST_PATH):
        log("ERROR: manifest.yaml not found.")
        sys.exit(1)
    with open(MANIFEST_PATH, "r") as f:
        return yaml.safe_load(f)


def get_vars(manifest):
    """
    Extract all template variables from the manifest.
    This is the single place where manifest fields map to template placeholders.
    """
    svc   = manifest["services"]
    nginx = manifest["nginx"]
    net   = manifest["network"]

    return {
        "SERVICE_NAME":    svc.get("name", "swiftdeploy-app"),
        "SERVICE_IMAGE":   svc["image"],
        "SERVICE_PORT":    str(svc["port"]),
        "MODE":            svc.get("mode", "stable"),
        "APP_VERSION":     str(svc.get("version", "1.0.0")),
        "RESTART_POLICY":  svc.get("restart_policy", "unless-stopped"),
        "LOG_PATH":        svc.get("log_path", "/var/log/app"),
        "NGINX_IMAGE":     nginx["image"],
        "NGINX_PORT":      str(nginx["port"]),
        "PROXY_TIMEOUT":   str(nginx.get("proxy_timeout", 30)),
        "NETWORK_NAME":    net["name"],
        "NETWORK_DRIVER":  net.get("driver_type", "bridge"),
    }


def fill_template(template_path, variables):
    """
    Read a template file and replace all ${PLACEHOLDER} with real values.
    Returns the filled content as a string.
    """
    with open(template_path, "r") as f:
        content = f.read()

    for key, value in variables.items():
        content = content.replace(f"${{{key}}}", value)

    return content

# OPA integration
# Call OPA from inside the app container using docker exec
def query_opa(policy, input_data):
    url = f"http://localhost:8181/v1/data/{policy}"

    payload = {
        "input": input_data
    }

    try:
        res = requests.post(url, json=payload, timeout=5)

        if res.status_code != 200:
            return {"error": f"OPA returned HTTP {res.status_code}: {res.text}"}

        data = res.json()
        return data.get("result", {})

    except requests.exceptions.ConnectionError:
        return {"error": "Cannot connect to OPA (is it running?)"}

    except requests.exceptions.Timeout:
        return {"error": "OPA request timed out"}

    except Exception as e:
        return {"error": str(e)}
    
def append_history(entry):
    history_file = os.path.join(ROOT_DIR, "history.jsonl")
    with open(history_file, "a") as f:
        f.write(json.dumps(entry) + "\n")

def get_system_stats():
    disk_free_gb = shutil.disk_usage("/").free / (1024**3)
    cpu_load = os.getloadavg()[0] if platform.system() != "Windows" else 0.5
    memory_free_percent = 50

    return disk_free_gb, cpu_load, memory_free_percent

def write_snapshot(event, metrics, policy, extra=None):
    """
    Unified history writer for deploy/promote/status
    """
    entry = {
        "event": event,
        "timestamp": datetime.now(timezone.utc).isoformat(),
        "metrics": metrics or {},
        "policy": policy or {}
    }

    if extra:
        entry.update(extra)

    append_history(entry)
    
def get_metrics():
    manifest = load_manifest()
    svc_name = manifest["services"].get("name", "swiftdeploy-app")

    result = subprocess.run(
        f"docker exec {svc_name} wget -qO- http://localhost:3000/metrics",
        shell=True,
        capture_output=True,
        text=True
    )

    if result.returncode != 0:
        return None

    return result.stdout

def parse_metrics(text):
    metrics = {
        "requests": 0,
        "errors": 0,
        "p99": 0.0,
        "error_rate": 0.0
    }

    total_requests = 0
    error_requests = 0
    bucket_counts = {}  # {le_value: count}

    for line in text.splitlines():
        if line.startswith("#"):
            continue

        # total requests
        if line.startswith("http_requests_total{"):
            try:
                total_requests += float(line.split()[-1])
            except:
                pass

        # error requests (5xx only)
        if "http_requests_total{" in line and "status_code=\"5" in line:
            try:
                error_requests += float(line.split()[-1])
            except:
                pass

        # histogram buckets for P99 — grab the le value and count
        if line.startswith("http_request_duration_seconds_bucket{"):
            try:
                # extract le value e.g le="0.5"
                le_part = [p for p in line.split(",") if "le=" in p][0]
                le_val = le_part.split('"')[1]
                count = float(line.split()[-1])
                if le_val != "+Inf":
                    bucket_counts[float(le_val)] = count
            except:
                pass

    metrics["requests"] = total_requests
    metrics["errors"] = error_requests

    # calculate error rate as percentage
    if total_requests > 0:
        metrics["error_rate"] = (error_requests / total_requests) * 100
    else:
        metrics["error_rate"] = 0.0

    # calculate P99 from histogram buckets
    # P99 = find the smallest bucket where count >= 99% of total requests
    if bucket_counts and total_requests > 0:
        p99_threshold = total_requests * 0.99
        for le_val in sorted(bucket_counts.keys()):
            if bucket_counts[le_val] >= p99_threshold:
                metrics["p99"] = le_val * 1000  # convert to ms
                break
        else:
            # requests exceeded all buckets — use largest bucket value
            metrics["p99"] = sorted(bucket_counts.keys())[-1] * 1000

    return metrics

def get_policy_status():
    metrics_raw = get_metrics()
    metrics = parse_metrics(metrics_raw) if metrics_raw else {}

    infra = query_opa("infrastructure", {
        "disk_free_gb": 50,
        "cpu_load": 0.5,
        "memory_free_percent": 80
    })

    canary = query_opa("canary", {
        "error_rate": metrics.get("error_rate", 0.0),
        "p99_latency_ms": metrics.get("p99", 0.0)
    })

    return {
        "infra": infra,
        "canary": canary
    }


# SUBCOMMANDS

# init
def cmd_init():
    """
    Read manifest.yaml, fill the templates, write nginx.conf and docker-compose.yml.
    This is the foundation — everything else depends on these generated files.
    """
    log("Reading manifest.yaml...")
    manifest = load_manifest()
    variables = get_vars(manifest)

    log("Generating nginx.conf from template...")
    nginx_content = fill_template(NGINX_TEMPLATE, variables)
    with open(NGINX_OUT, "w") as f:
        f.write(nginx_content)
    success(f"nginx.conf written to {NGINX_OUT}")

    log("Generating docker-compose.yml from template...")
    compose_content = fill_template(COMPOSE_TEMPLATE, variables)
    with open(COMPOSE_OUT, "w") as f:
        f.write(compose_content)
    success(f"docker-compose.yml written to {COMPOSE_OUT}")

    log("Init complete.")


#  validate 
def cmd_validate():
    """
    Run 5 pre-flight checks before deploying.
    Print pass/fail for each. Exit non-zero if any fail.
    """
    log("Running pre-flight validation checks...\n")
    passed = True

    # Check if manifest.yaml exists and is valid YAML 
    print("Check 1: manifest.yaml exists and is valid YAML")
    try:
        if not os.path.exists(MANIFEST_PATH):
            raise FileNotFoundError("manifest.yaml not found")
        with open(MANIFEST_PATH, "r") as f:
            manifest = yaml.safe_load(f)
        if manifest is None:
            raise ValueError("manifest.yaml is empty")
        success("manifest.yaml exists and is valid YAML")
    except Exception as e:
        fail(f"manifest.yaml check failed: {e}")
        passed = False
        manifest = None

    # Check if all required fields are present and non-empty 
    print("\nCheck 2: All required fields present and non-empty")
    required_fields = [
        ("services.image",       lambda m: m["services"]["image"]),
        ("services.port",        lambda m: m["services"]["port"]),
        ("nginx.image",          lambda m: m["nginx"]["image"]),
        ("nginx.port",           lambda m: m["nginx"]["port"]),
        ("network.name",         lambda m: m["network"]["name"]),
        ("network.driver_type",  lambda m: m["network"]["driver_type"]),
    ]

    if manifest:
        all_fields_ok = True
        for field_name, getter in required_fields:
            try:
                value = getter(manifest)
                if value is None or str(value).strip() == "":
                    raise ValueError(f"field is empty")
                success(f"{field_name} = {value}")
            except Exception as e:
                fail(f"{field_name} missing or empty: {e}")
                all_fields_ok = False
                passed = False
        if all_fields_ok:
            success("All required fields present")
    else:
        fail("Skipping field check, manifest could not be loaded")
        passed = False

    # Check if Docker image exists locally 
    print("\nCheck 3: Docker image exists locally")
    if manifest:
        image = manifest["services"]["image"]
        result = subprocess.run(
            f'docker image inspect {image}',
            shell=True, capture_output=True, text=True
        )
        if result.returncode == 0:
            success(f"Image '{image}' found locally")
        else:
            fail(f"Image '{image}' not found locally. Run: docker build -t {image} ./app")
            passed = False

    # Check if Nginx port is not already bound on the host 
    print("\nCheck 4: Nginx port is not already bound on the host")
    if manifest:
        nginx_port = int(manifest["nginx"]["port"])
        sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        sock.settimeout(1)
        result = sock.connect_ex(("localhost", nginx_port))
        sock.close()
        if result == 0:
            fail(f"Port {nginx_port} is already in use. Free it before deploying.")
            passed = False
        else:
            success(f"Port {nginx_port} is free")

    # Check if nginx.conf syntax is valid
    print("\nCheck 5: nginx.conf syntax is valid")
    if not os.path.exists(NGINX_OUT):
        fail("nginx.conf not found. Run: ./swiftdeploy init first")
        passed = False
    else:
        # Use a minimal nginx.conf that doesn't reference the upstream
        # because the app container doesn't exist yet at validate time
            test_config = """
        events {}
        http {
            server {
                listen 8080;
                location / {
                    return 200 'ok';
                }
            }
        }
        """
            test_config_path = os.path.join(ROOT_DIR, "nginx.test.conf")
            with open(test_config_path, "w") as f:
                f.write(test_config)

            result = subprocess.run(
                f"docker run --rm -v {ROOT_DIR}/nginx.test.conf:/etc/nginx/nginx.conf:ro nginx:latest nginx -t",
                shell=True, capture_output=True, text=True
            )
            os.remove(test_config_path)

            if result.returncode == 0:
                success("nginx.conf syntax is valid")
            else:
                fail(f"nginx.conf has syntax errors:\n{result.stderr}")
                passed = False

    # Final result
    print()
    if passed:
        log("All checks passed. Ready to deploy.")
    else:
        log("One or more checks failed. Fix the issues above before deploying.")
        sys.exit(1)


# deploy
def cmd_deploy():
    log("Starting deployment...")

    # Step 1 — generate config files
    cmd_init()

    # Step 2 — start OPA container before the app
    log("Starting OPA...")
    run(f"docker compose -f {COMPOSE_OUT} up -d opa")
    time.sleep(3)  # give OPA time to boot

    # Step 3 — collect host stats using helper
    disk_free_gb, cpu_load, memory_free_percent = get_system_stats()

    # Step 4 — pre-deploy OPA check
    log("Running pre-deploy policy check...")
    opa_result = query_opa("infrastructure", {
        "disk_free_gb": disk_free_gb,
        "cpu_load": cpu_load,
        "memory_free_percent": memory_free_percent
    })

    if "error" in opa_result:
        fail(f"OPA error: {opa_result['error']}")
        sys.exit(1)

    if not opa_result.get("allow", True):
        fail("Deployment blocked by policy:")
        for msg in opa_result.get("deny", []):
            print(" -", msg)
        sys.exit(1)

    success("Pre-deploy policy passed")

    # Step 5 — bring up the full stack
    log("Starting containers with docker compose...")
    run(f"docker compose -f {COMPOSE_OUT} up -d --build")

    # Step 6 — wait for health checks
    log("Waiting for health checks to pass (timeout: 60s)...")
    manifest = load_manifest()
    svc_name = manifest["services"].get("name", "swiftdeploy-app")
    timeout  = 60
    start    = time.time()

    while time.time() - start < timeout:
        result = subprocess.run(
            f'docker inspect --format="{{{{.State.Health.Status}}}}" {svc_name}',
            shell=True, capture_output=True, text=True
        )
        status = result.stdout.strip().strip('"')

        if status == "healthy":
            success(f"Container '{svc_name}' is healthy")
            log("Stack is up and running.")
            log(f"Access your app at: http://localhost:{manifest['nginx']['port']}")

            # collect metrics and write snapshot after healthy
            metrics_raw = get_metrics()
            metrics = parse_metrics(metrics_raw) if metrics_raw else {}

            write_snapshot(
                event="deploy",
                metrics=metrics,
                policy={
                    "infra": opa_result,
                    "canary": {}
                }
            )
            return

        elapsed = int(time.time() - start)
        print(f"  ... waiting ({elapsed}s) — current status: {status}")
        time.sleep(5)

    log("ERROR: Health check timed out after 60s.")
    log("Check container logs with: docker logs " + svc_name)
    sys.exit(1)


# promote 
def cmd_promote(mode):

    if mode not in ("stable", "canary"):
        log(f"ERROR: invalid mode '{mode}'. Use: stable or canary")
        sys.exit(1)

    log(f"Promoting to {mode} mode...")

    # collect host stats early so they're available throughout
    disk_free_gb, cpu_load, memory_free_percent = get_system_stats()

    # Step 1 — pre-promote OPA check using canary metrics
    log("Running pre-promote policy check...")

    manifest = load_manifest()
    svc_name = manifest["services"].get("name", "swiftdeploy-app")
    svc_port = manifest["services"]["port"]

    result = subprocess.run(
        f'docker exec {svc_name} wget -qO- http://localhost:{svc_port}/metrics',
        shell=True, capture_output=True, text=True
    )

    if result.returncode != 0:
        fail("Could not fetch metrics from app container")
        sys.exit(1)

    raw_metrics = result.stdout

    # derive error rate and latency from chaos state
    error_rate  = 5.0  if "chaos_active 2" in raw_metrics else 0.0
    p99_latency = 1000 if "chaos_active 1" in raw_metrics else 100

    opa_result = query_opa("canary", {
        "error_rate": error_rate,
        "p99_latency_ms": p99_latency
    })

    if "error" in opa_result:
        fail(f"OPA error: {opa_result['error']}")
        sys.exit(1)

    if not opa_result.get("allow", True):
        fail("Promotion blocked by policy:")
        for msg in opa_result.get("deny", []):
            print(" -", msg)
        sys.exit(1)

    success("Pre-promote policy passed")

    # Step 2 — update manifest.yaml mode in place
    manifest["services"]["mode"] = mode
    with open(MANIFEST_PATH, "w") as f:
        yaml.dump(manifest, f, default_flow_style=False, sort_keys=False)
    success(f"manifest.yaml updated: mode = {mode}")

    # Step 3 — regenerate docker-compose.yml with new MODE
    cmd_init()

    # Step 4 — restart only the service container
    log(f"Restarting service container '{svc_name}'...")
    run(f"docker compose -f {COMPOSE_OUT} up -d --no-deps {svc_name}")
    success(f"Container '{svc_name}' restarted")

    # Step 5 — confirm new mode via /healthz
    log("Confirming new mode via /healthz...")
    time.sleep(5)

    result = subprocess.run(
        f'docker exec {svc_name} wget --quiet -O - http://localhost:{svc_port}/healthz',
        shell=True, capture_output=True, text=True
    )

    if result.returncode != 0:
        fail("Could not confirm new mode via /healthz")
        log(result.stderr)
        sys.exit(1)

    success(f"/healthz response: {result.stdout.strip()}")
    log(f"Promotion to {mode} complete.")

    # Step 6 — write snapshot after successful promotion
    metrics_raw = get_metrics()
    metrics = parse_metrics(metrics_raw) if metrics_raw else {}

    infra_policy = query_opa("infrastructure", {
        "disk_free_gb": disk_free_gb,
        "cpu_load": cpu_load,
        "memory_free_percent": memory_free_percent
    })

    write_snapshot(
        event="promote",
        metrics=metrics,
        policy={
            "infra": infra_policy,
            "canary": opa_result
        },
        extra={"mode": mode}
    )

# teardown 
def cmd_teardown(clean=False):
    """
    Stop and remove all containers, networks, and volumes.
    With --clean: also delete the generated nginx.conf and docker-compose.yml.
    """
    log("Tearing down the stack...")

    if os.path.exists(COMPOSE_OUT):
        run(f"docker compose -f {COMPOSE_OUT} down -v --remove-orphans")
        success("Containers, networks, and volumes removed")
    else:
        log("No docker-compose.yml found. Skipping docker compose down.")

    if clean:
        log("Cleaning up generated config files...")
        for path in [NGINX_OUT, COMPOSE_OUT]:
            if os.path.exists(path):
                os.remove(path)
                success(f"Deleted {path}")
        log("Clean complete.")

    log("Teardown complete.")

def cmd_status():
    log("Starting live status dashboard... (Ctrl+C to stop)")

    while True:
        metrics_raw = get_metrics()

        if not metrics_raw:
            fail("Cannot fetch metrics — is the stack running?")
            time.sleep(2)
            continue

        metrics  = parse_metrics(metrics_raw)
        policies = get_policy_status()

        # write to history
        write_snapshot(
            event="status",
            metrics=metrics,
            policy=policies
        )

        # clear screen and display dashboard
        os.system("cls" if os.name == "nt" else "clear")

        print("=" * 40)
        print("       SWIFTDEPLOY STATUS DASHBOARD")
        print("=" * 40)
        print(f"  Total Requests  : {metrics['requests']}")
        print(f"  Error Requests  : {metrics['errors']}")
        print(f"  Error Rate      : {metrics['error_rate']:.2f}%")
        print(f"  P99 Latency     : {metrics['p99']:.1f}ms")
        print()
        print("  Policy Compliance:")
        infra_status  = "✔ PASS" if policies['infra'].get('allow', True) else "✘ FAIL"
        canary_status = "✔ PASS" if policies['canary'].get('allow', True) else "✘ FAIL"
        print(f"  Infrastructure  : {infra_status}")
        print(f"  Canary Safety   : {canary_status}")

        # show denial reasons if any policy is failing
        infra_deny  = policies['infra'].get('deny', [])
        canary_deny = policies['canary'].get('deny', [])

        if infra_deny or canary_deny:
            print()
            print("  Policy Violations:")
            for msg in infra_deny:
                print(f"    ✘ [infra]  {msg}")
            for msg in canary_deny:
                print(f"    ✘ [canary] {msg}")

        print()
        print("  Press Ctrl+C to stop")
        print("=" * 40)

        time.sleep(3)
        
def cmd_audit():
    history_file = os.path.join(ROOT_DIR, "history.jsonl")
    output_file  = os.path.join(ROOT_DIR, "audit_report.md")

    if not os.path.exists(history_file):
        log("No history found. Run deploy/promote first.")
        return

    entries = []
    with open(history_file, "r", encoding="utf-8") as f:
        for line in f:
            try:
                entries.append(json.loads(line))
            except:
                continue

    if not entries:
        log("History is empty")
        return

    md = []
    md.append("# SwiftDeploy Audit Report\n")
    md.append(f"Generated: {datetime.now(timezone.utc).strftime('%Y-%m-%d %H:%M:%S UTC')}\n")
    md.append(f"Total events recorded: {len(entries)}\n")

    # ── Timeline — only deploy and promote events ─────────────────────────────
    md.append("## Event Timeline\n")
    md.append("| Timestamp | Event | Mode | Requests | Errors | Error Rate | P99 |")
    md.append("|-----------|-------|------|----------|--------|------------|-----|")

    lifecycle_events = [e for e in entries if e.get("event") in ("deploy", "promote")]

    if lifecycle_events:
        for entry in lifecycle_events:
            ts         = entry.get("timestamp", "")[:19].replace("T", " ")
            event      = entry.get("event", "")
            mode       = entry.get("mode", entry.get("extra", {}).get("mode", "stable"))
            metrics    = entry.get("metrics", {})
            requests   = metrics.get("requests", 0)
            errors     = metrics.get("errors", 0)
            error_rate = metrics.get("error_rate", 0.0)
            p99        = metrics.get("p99", 0.0)
            md.append(f"| {ts} | {event} | {mode} | {requests} | {errors} | {error_rate:.2f}% | {p99:.0f}ms |")
    else:
        md.append("| — | No deploy/promote events found | — | — | — | — | — |")

    md.append("")

    # ── Policy Violations summary ─────────────────────────────────────────────
    md.append("## Policy Violations\n")

    # group violations by type and count them instead of listing every single one
    infra_violations  = []
    canary_violations = []

    for entry in entries:
        infra  = entry.get("policy", {}).get("infra", {})
        canary = entry.get("policy", {}).get("canary", {})

        if not infra.get("allow", True):
            for msg in infra.get("deny", []):
                clean_msg = msg.encode("ascii", "replace").decode("ascii").replace("?", "-")
                infra_violations.append((entry.get("timestamp", "")[:19].replace("T", " "), clean_msg))

        if not canary.get("allow", True):
            for msg in canary.get("deny", []):
                clean_msg = msg.encode("ascii", "replace").decode("ascii").replace("?", "-")
                canary_violations.append((entry.get("timestamp", "")[:19].replace("T", " "), clean_msg))

    if not infra_violations and not canary_violations:
        md.append("No policy violations recorded.\n")
    else:
        if infra_violations:
            md.append("### Infrastructure Violations\n")
            md.append(f"Total occurrences: {len(infra_violations)}\n")
            md.append("| First seen | Last seen | Reason |")
            md.append("|------------|-----------|--------|")
            # show first and last only
            first_ts, first_msg = infra_violations[0]
            last_ts, _          = infra_violations[-1]
            md.append(f"| {first_ts} | {last_ts} | {first_msg} |")
            md.append("")

        if canary_violations:
            md.append("### Canary Violations\n")
            md.append(f"Total occurrences: {len(canary_violations)}\n")
            md.append("| First seen | Last seen | Reason |")
            md.append("|------------|-----------|--------|")
            first_ts, first_msg = canary_violations[0]
            last_ts, _          = canary_violations[-1]
            md.append(f"| {first_ts} | {last_ts} | {first_msg} |")
            md.append("")

    with open(output_file, "w", encoding="utf-8") as f:
        f.write("\n".join(md))

    success(f"Audit report generated -> {output_file}")

# Usage info

def print_usage():
    print("""
    SwiftDeploy — Declarative deployment CLI

    Usage: ./swiftdeploy <subcommand> [options]

    Subcommands:
    init                Generate nginx.conf and docker-compose.yml from manifest.yaml
    validate            Run pre-flight checks before deploying
    deploy              Init + bring up the stack + wait for health checks
    promote <mode>      Switch deployment mode: stable or canary
    teardown            Stop and remove all containers, networks, volumes
    teardown --clean    Teardown + delete generated config files
    """)


if __name__ == "__main__":          
    args = sys.argv[1:]

    if not args:
        print_usage()
        sys.exit(0)

    command = args[0]

    if command == "init":
        cmd_init()

    elif command == "validate":
        cmd_validate()

    elif command == "deploy":
        cmd_deploy()

    elif command == "promote":
        if len(args) < 2:
            log("ERROR: promote requires a mode argument: stable or canary")
            sys.exit(1)
        cmd_promote(args[1])

    elif command == "teardown":
        clean = "--clean" in args
        cmd_teardown(clean)
        
    elif command == "status":
        cmd_status()

    elif command == "audit":
        cmd_audit()

    else:
        log(f"ERROR: unknown command '{command}'")
        print_usage()
        sys.exit(1)
